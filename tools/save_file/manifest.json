{
  "name": "save_file",
  "description": "将内容保存为本地文件（txt/md/json/csv/py 等），完成后在资源管理器中打开所在目录。保存目录可在设置→工具中配置，默认为下载文件夹",
  "script": "tool.py",
  "parameters": {
    "filename": {
      "type": "string",
      "description": "文件名（含扩展名），如 'report.md'、'data.csv'、'notes.txt'",
      "source": "ai",
      "required": true
    },
    "content": {
      "type": "string",
      "description": "要写入文件的文本内容",
      "source": "ai",
      "required": true
    },
    "save_dir": {
      "type": "string",
      "description": "保存目录（由配置提供，AI 无需填写）",
      "source": "config",
      "required": false
    }
  }
}
